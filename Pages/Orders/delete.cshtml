@page
@model DeleteModel
<h2>Delete Order</h2>
<h4>Do you want to delete this order?</h4>

@if (Model.Order != null)
{
<div>
<p>@Model.Order.ID</p>
    <p>@Model.Order.CustomerName</p>
    <p>@Model.Order.ProductName</p>
    <p>@Model.Order.quantity</p>
    <p>@Model.Order.Price</p>
    <p>@Model.Order.OrderDate</p>
</div>

<form method="post">
<input type="hidden" asp-for="Order.ID"/>
<button type="submit" class="btn btn-danger">Delete</button>
<a asp-page="Product" class="btn btn-secondary">Cancel</a>

</form>
}
else
{
<p>Order not found.</p>
}