@page 
@model ProductModel 
<h1 class="mb-3"> Order List</h1> 
<div class=" d-flex justify-content-end mb-3"> 
<a asp-page="create" class="btn btn-success ">Add New Order</a> 
</div> 
<div class="container table-responsive"> 
<table class="table table-bordered table-striped text-center table-responsive" > 
<thead class="table-dark"> 
<tr> 
<th>ID</th> 
<th>CustomerName</th> 
<th>ProductName</th> 
<th>Quantity</th> 
<th>Price</th> 
<th>OrderDate</th>
<th>Actions</th>  
</tr> 
</thead> 
<tbody>    
@foreach (var Order in Model.Orders){ 
                 <tr>
                    <td>@Order.ID</td>
                    <td>@Order.CustomerName</td>
                    <td>@Order.ProductName</td>
                    <td>@Order.quantity</td>
                    <td>@Order.Price</td>
                    <td>@Order.OrderDate</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@Order.ID" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-page="delete" asp-route-id="@Order.ID" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
                    } 
</tbody></table> 
</div>